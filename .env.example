# Copy to `.env` locally or configure secrets in GitHub Actions / your host.

# Supabase Postgres — Dashboard → Project Settings → Database → Connection string (URI).
# URL-encode special characters in the password (@ → %40, # → %23, $ → %24).
# On Hostinger/Linux, include sslmode=require (or use db.*.supabase.co — SSL is auto-enabled).
# Example (direct): postgresql://postgres:YOUR_PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require
# Hostinger: use Supabase "Session pooler" URI in DATABASE_URL (see README Deployment).
DATABASE_URL=

# Optional: direct Postgres URL on port 5432 for `pnpm --filter @workspace/db run push`
# when DATABASE_URL uses Transaction pooler (pgbouncer) only.
# DATABASE_DIRECT_URL=

# API server (@workspace/api-server)
PORT=8080
SESSION_SECRET=
ADMIN_PASSWORD=

# Leads (Phase 2) — optional email via Resend (https://resend.com)
# RESEND_API_KEY=
# LEAD_NOTIFY_EMAIL=info@precisefect.com
# LEAD_NOTIFY_FROM=Precisefect <notifications@yourdomain.com>
# SITE_URL=https://yourdomain.com
# Public API base URL for inbound integration webhooks (Zapier/Make)
# API_PUBLIC_URL=https://api.yourdomain.com

# Encrypt integration secrets at rest (32+ char random string)
# INTEGRATION_ENCRYPTION_KEY=
# Optional: absolute path to precisefect build (default: artifacts/api-server/dist/public next to index.mjs)
# STATIC_ROOT=

# Supabase Storage (public bucket for CMS media)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=cms-assets

# Precisefect Vite dev (@workspace/precisefect)
# PORT=5173
# BASE_PATH=/
# VITE_DEV_API_PROXY=http://127.0.0.1:8080
